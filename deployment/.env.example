# --- Öffentliche Adresse (https://bfsg-fix.de) ---
PUBLIC_URL=https://bfsg-fix.de

# --- Stripe (Live-Keys, NIE committen) ---
STRIPE_SECRET_KEY=sk_live_oder_rk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Brevo SMTP ---
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=DEIN_BREVO_SMTP_USER
SMTP_PASS=DEIN_BREVO_SMTP_KEY
FROM_EMAIL=no-reply@bfsg-fix.de
FROM_NAME=BFSG-Check
REPLY_TO=hello@bfsg-fix.de

# Kontaktadresse fuer Rueckfragen (Rechnung + Reply-To/List-Unsubscribe der
# Transaktionsmails). NICHT die no-reply-Sendeadresse. Default info@bfsg-fix.de.
# Postfach muss empfangen koennen. REPLY_TO (falls gesetzt) hat Vorrang.
INVOICE_CONTACT_EMAIL=info@bfsg-fix.de

# --- Betreiber-Alarm bei Erfüllungsfehler ---
ADMIN_EMAIL=matze.seba@outlook.de

# --- Rechnungs-Pflichtangaben (§ 14 UStG) ---
# PFLICHT vor Launch: ohne diese Werte trägt jede Rechnungs-PDF einen Platzhalter
# als Anbieter-Anschrift → formell fehlerhafte Rechnung. Echte Werte NUR hier im
# Server-.env eintragen (NICHT in dieses Template/Repo committen).
INVOICE_FROM_NAME=Vorname Nachname
INVOICE_FROM_ADDRESS=Strasse Hausnr., PLZ Ort
# VAT_MODE=kleinunternehmer (§19 UStG, keine USt-Ausweisung) | regelbesteuerung (19% USt)
VAT_MODE=kleinunternehmer

# --- Admin-Token für /api/admin/* (langes Zufallsgeheimnis, z.B. openssl rand -hex 32) ---
ADMIN_TOKEN=langes_zufallsgeheimnis_hier_eintragen

# --- Sentry (optional, leer lassen = aus) ---
SENTRY_DSN=

# --- Re-Check-Abo: erst auf 'true' setzen, NACHDEM Abo-Lifecycle live getestet ist ---
ENABLE_ABO=false

# --- Concurrency Gratis-Teaser (Default 2 reicht für CX22 mit 4 GB RAM) ---
MAX_CONCURRENT_SCANS=2
# Warteschlangen-Cap Gratis-Teaser: bei vollem Stau sofort 503 (busy) statt
# unbegrenzt wachsender Queue. Default 40.
SCAN_QUEUE_MAX=40
# Rate-Limit Gratis-Teaser (Anfragen/Minute/IP). Default 15 (hoch genug gegen
# False-Trips bei NAT/Büro-IPs, niedrig genug als Kosten-/DoS-Schutz).
SCAN_RATE_MAX=15
# Concurrency BEZAHLTER Scans (eigenes Gate, kein Queue-Cap → Bestellungen werden
# nie abgewiesen). Default 1 hält die Browser-Spitze klein. Auf dem 4-GB-Host bei
# Bedarf MAX_CONCURRENT_SCANS=1 setzen, damit die Gesamt-Browser-Spitze bei 2 bleibt.
MAX_CONCURRENT_PAID_SCANS=1
# Speicher-Limit des App-Containers (OOM-Backstop, docker-compose mem_limit).
# Default 3g (passt auf 4-GB-Host: lässt ~1 GB für die übrigen Container + OS).
APP_MEM_LIMIT=3g

# --- Gratis-Teaser: TLS-Toleranz (NUR Gratischeck, Default false = strikt) ---
# true erlaubt dem KOSTENLOSEN Teaser-Scan, Seiten mit unvollständiger/abgelaufener
# Zertifikatskette trotzdem zu prüfen (viele kleine SMB-Seiten). Der BEZAHLTE Scan
# bleibt IMMER strikt. SSRF-/DNS-Rebinding-Schutz ist davon unberührt.
SCAN_TEASER_LENIENT_TLS=false

# --- Newsletter via Brevo Double-Opt-in (optional; leer = Footer-Formular meldet
#     "gerade nicht verfügbar"). Voraussetzung in Brevo: eine dedizierte
#     Newsletter-Liste + ein AKTIVES Double-Opt-in-Template anlegen, dann hier: ---
BREVO_API_KEY=
BREVO_NEWSLETTER_LIST_ID=
BREVO_DOI_TEMPLATE_ID=
BREVO_DOI_REDIRECT_URL=https://bfsg-fix.de/?newsletter=bestaetigt
