# --- Öffentliche Adresse (https://bfsg-fix.de) ---
PUBLIC_URL=https://bfsg-fix.de

# --- Stripe (Live-Keys, NIE committen) ---
STRIPE_SECRET_KEY=sk_live_oder_rk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Brevo SMTP ---
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=DEIN_BREVO_SMTP_USER
SMTP_PASS=DEIN_BREVO_SMTP_KEY
FROM_EMAIL=no-reply@bfsg-fix.de
FROM_NAME=BFSG-Check
REPLY_TO=hello@bfsg-fix.de

# Kontaktadresse fuer Rueckfragen (Rechnung + Reply-To/List-Unsubscribe der
# Transaktionsmails). NICHT die no-reply-Sendeadresse. Default info@bfsg-fix.de.
# Postfach muss empfangen koennen. REPLY_TO (falls gesetzt) hat Vorrang.
INVOICE_CONTACT_EMAIL=info@bfsg-fix.de

# --- Betreiber-Alarm bei Erfüllungsfehler ---
ADMIN_EMAIL=matze.seba@outlook.de

# --- Rechnungs-Pflichtangaben (§ 14 UStG) ---
# PFLICHT vor Launch: ohne INVOICE_FROM_ADDRESS bleibt die Anbieter-Anschrift auf der
# Rechnung LEER (formell fehlerhaft) — app.js alarmiert beim Start im Live-Betrieb.
# Echte Werte NUR hier im Server-.env eintragen (NICHT in dieses Template/Repo committen).
INVOICE_FROM_NAME=Vorname Nachname
INVOICE_FROM_ADDRESS=Strasse Hausnr., PLZ Ort
# Steuernummer ODER USt-IdNr.: seit 01.01.2025 auch für Kleinunternehmer ab 250 € brutto
# Pflicht (§ 33/34a UStDV) — relevant fürs Profi-Paket (399 €). Eine von beiden setzen:
INVOICE_TAX_NUMBER=12/345/67890
# INVOICE_USTID=DE123456789
# VAT_MODE=kleinunternehmer (§19 UStG, keine USt-Ausweisung) | regelbesteuerung (19% USt)
VAT_MODE=kleinunternehmer

# --- Admin-Token für /api/admin/* (langes Zufallsgeheimnis, z.B. openssl rand -hex 32) ---
ADMIN_TOKEN=langes_zufallsgeheimnis_hier_eintragen

# --- Sentry (optional, leer lassen = aus) ---
SENTRY_DSN=

# --- Re-Check-Abo: erst auf 'true' setzen, NACHDEM Abo-Lifecycle live getestet ist ---
ENABLE_ABO=false

# --- Concurrency Gratis-Teaser (Default 2 reicht für CX22 mit 4 GB RAM) ---
MAX_CONCURRENT_SCANS=2
# Warteschlangen-Cap Gratis-Teaser: bei vollem Stau sofort 503 (busy) statt
# unbegrenzt wachsender Queue. Default 40.
SCAN_QUEUE_MAX=40
# Rate-Limit Gratis-Teaser (Anfragen/Minute/IP). Default 15 (hoch genug gegen
# False-Trips bei NAT/Büro-IPs, niedrig genug als Kosten-/DoS-Schutz).
SCAN_RATE_MAX=15
# Concurrency BEZAHLTER Scans (eigenes Gate, kein Queue-Cap → Bestellungen werden
# nie abgewiesen). Default 1 hält die Browser-Spitze klein. Auf dem 4-GB-Host bei
# Bedarf MAX_CONCURRENT_SCANS=1 setzen, damit die Gesamt-Browser-Spitze bei 2 bleibt.
MAX_CONCURRENT_PAID_SCANS=1
# Speicher-Limit des App-Containers (OOM-Backstop, docker-compose mem_limit).
# Default 3g (passt auf 4-GB-Host: lässt ~1 GB für die übrigen Container + OS).
APP_MEM_LIMIT=3g

# --- TLS-Toleranz (env-gated, getrennt je Pfad, Default false = strikt) ---
# Teaser: true erlaubt dem KOSTENLOSEN Scan, Seiten mit unvollständiger/abgelaufener
# Zertifikatskette trotzdem zu prüfen (viele kleine SMB-Seiten).
SCAN_TEASER_LENIENT_TLS=false
# Bezahlter Pfad: SEPARATES Flag, KEIN Fallback auf das Teaser-Flag. Nur auf true
# setzen, wenn der verkaufte Report bewusst auch Cert-Mismatch-Seiten ausliefern soll
# (z. B. matthias-seba.de mit Hostname-Mismatch-Cert). Sonst scheitert der Bezahl-Scan
# bei genau den Seiten, die der Gratis-Teaser leniant bestanden hat. SSRF-Schutz unberührt.
SCAN_PAID_LENIENT_TLS=false

# --- PR4: KI-Report-QA-Agent (optional; Default AUS = dormant, fail-open) ---
# Prüft/überarbeitet jeden BFSG-Report vor Auslieferung. Ohne Key + Flag passiert
# nichts (der Report geht unverändert raus). ANTHROPIC_API_KEY: eigenes API-Konto
# unter console.anthropic.com (NICHT das Max-Abo). Monatscap in der Console setzen.
ANTHROPIC_API_KEY=
REPORT_QA_ENABLED=false
# Modell: claude-sonnet-4-6 (Kosten/Qualität) oder claude-opus-4-8 (max. Qualität).
REPORT_QA_MODEL=claude-sonnet-4-6
REPORT_QA_TIMEOUT_MS=90000
REPORT_QA_MAX_TOKENS=8000

# --- PR5: Owner-Release-Gate --------------------------------------------------
# Jeder fertige Report geht ZUERST an den Owner (ADMIN_EMAIL) mit 1-Klick-Freigabe-
# Link; klickt der Owner nichts, wird der Report nach RELEASE_DELAY_MIN Minuten
# automatisch an den Kunden versendet. Hält den Claim "jeder Report wird gesichtet"
# wahr. Default AN. Auf false = sofortiger Auto-Versand (dann Claims wahr formulieren).
REPORT_RELEASE_GATE_ENABLED=true
RELEASE_DELAY_MIN=90
SCHEDULER_INTERVAL_MS=60000
# Signaturschlüssel für den Freigabe-Link (optional; Fallback = ADMIN_TOKEN).
RELEASE_TOKEN_SECRET=

# --- Newsletter via Brevo Double-Opt-in (optional; leer = Footer-Formular meldet
#     "gerade nicht verfügbar"). Voraussetzung in Brevo: eine dedizierte
#     Newsletter-Liste + ein AKTIVES Double-Opt-in-Template anlegen, dann hier: ---
BREVO_API_KEY=
BREVO_NEWSLETTER_LIST_ID=
BREVO_DOI_TEMPLATE_ID=
BREVO_DOI_REDIRECT_URL=https://bfsg-fix.de/?newsletter=bestaetigt

# --- Scan-Lead-Capture via Brevo Double-Opt-in (Value-first-Funnel; optional;
#     leer = Lead-Formular am Scan-Ergebnis meldet "gerade nicht verfügbar").
#     Voraussetzung in Brevo: (1) eine dedizierte "Scan-Leads"-Liste, (2) ein
#     AKTIVES Double-Opt-in-Template (oder BREVO_DOI_TEMPLATE_ID oben als Fallback),
#     (3) drei Kontakt-Attribute anlegen: SCAN_URL (Text), SCAN_SCORE (Zahl),
#     SCAN_ISSUES (Zahl) — fehlen sie, wird der Lead trotzdem ohne Attribute eingetragen. ---
BREVO_LEAD_LIST_ID=
BREVO_LEAD_DOI_TEMPLATE_ID=
BREVO_LEAD_DOI_REDIRECT_URL=https://bfsg-fix.de/?lead=bestaetigt
