# Caddyfile — Reverse-Proxy mit automatischem Let's-Encrypt-SSL.
# Caddy holt + erneuert die Zertifikate von allein, sobald DNS auf den Server zeigt.

# === Haupt-Domain ===
bfsg-fix.de, www.bfsg-fix.de {
    reverse_proxy app:8080

    encode gzip

    # Ergänzende Sicherheits-Header (zusätzlich zu denen in app.js)
    # Hinweis: Rate-Limit NICHT via Caddy-Plugin — bleibt App-Level
    # (scanner/lib/limits.js) oder via Cloudflare-Proxy (Welle 5).
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
        Content-Security-Policy "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' https://js.stripe.com; frame-src https://js.stripe.com https://hooks.stripe.com; connect-src 'self' https://api.stripe.com; font-src 'self' data:; object-src 'none'; base-uri 'self'; form-action 'self' https://checkout.stripe.com"
        Cross-Origin-Opener-Policy "same-origin"
        X-XSS-Protection "1; mode=block"
        -Server
    }

    # Stripe-Webhook braucht den rohen Body — kein Buffering durch Caddy.
    @webhook path /webhook
    handle @webhook {
        reverse_proxy app:8080 {
            flush_interval -1
        }
    }

    log {
        output stdout
        format console
        level INFO
    }
}

# === Alias-Domains: 301-Redirect auf Haupt-Domain ===
# (Behalten ihren Wert für SEO/Direktaufruf, leiten aber sauber weiter.)
bfsg-barrierecheck.de, www.bfsg-barrierecheck.de {
    redir https://bfsg-fix.de{uri} permanent
}

bfsg-sofortcheck.de, www.bfsg-sofortcheck.de {
    redir https://bfsg-fix.de{uri} permanent
}

barrierefrei-pruefen.de, www.barrierefrei-pruefen.de {
    redir https://bfsg-fix.de{uri} permanent
}

# === Künftige Sub-Domains (DNS-Records siehe deployment/dns-records.md) ===
# Container-Targets sind Platzhalter — werden in Welle 4/5 hochgezogen.

preview.bfsg-fix.de {
    reverse_proxy landing-next:3000
    encode gzip
    header Strict-Transport-Security "max-age=31536000; includeSubDomains"
    log {
        output stdout
        format console
        level INFO
    }
}

admin.bfsg-fix.de {
    reverse_proxy admin-next:3001
    encode gzip
    header Strict-Transport-Security "max-age=31536000; includeSubDomains"
    log {
        output stdout
        format console
        level INFO
    }
}
