# BFSG-Audit — Umgebungsvariablen
# Diese Datei kopieren nach ".env" (oder im Hosting als Variablen eintragen).
# NIEMALS echte Keys in Git committen oder in einen Chat schreiben!

# --- Öffentliche Adresse (für Stripe Erfolg-/Abbruch-Links) ---
PUBLIC_URL=https://bfsg-check.de
PORT=8080

# --- Stripe (du hast es bereits mit deinem Geschäftskonto verbunden) ---
# Findest du im Stripe-Dashboard: Entwickler -> API-Schlüssel
STRIPE_SECRET_KEY=sk_live_oder_test_xxx
# Webhook-Secret: Stripe-Dashboard -> Entwickler -> Webhooks -> Endpoint /webhook anlegen
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- E-Mail-Versand (SMTP eines Anbieters wie Brevo, Postmark, SendGrid) ---
SMTP_HOST=smtp.dein-anbieter.de
SMTP_PORT=587
SMTP_USER=dein-smtp-user
SMTP_PASS=dein-smtp-passwort
FROM_EMAIL=no-reply@bfsg-check.de
FROM_NAME=BFSG-Check

# --- Optional: Betreiber-Alarm bei Erfüllungsfehler ---
ADMIN_EMAIL=admin@bfsg-check.de

# --- Re-Check-Abo (MRR) ---
# Schaltet das monatliche Re-Check-Abo frei (Preis = PACKAGES.abo in scanner/app.js).
# Vor dem Scharfschalten (ENABLE_ABO=true) erforderlich:
#   1. Stripe-Webhook abonniert: checkout.session.completed, invoice.paid,
#      invoice.payment_succeeded, customer.subscription.updated,
#      customer.subscription.deleted (Dashboard -> Entwickler -> Webhooks).
#   2. Ein Test-Abo durchspielen (Stripe CLI `stripe trigger invoice.paid` ODER
#      echtes Test-Abo -> sofort kündigen): Re-Scan + Diff + aktualisierte
#      Erklärung + Rechnung + Mail müssen ankommen; Kündigungs-Bestätigung prüfen.
# Idempotenz: In-Memory-Claim gegen Parallel-Duplikate; erfüllte Bestellungen sind
# durabel dedupliziert (recordPaid persistiert die event.id VOR der Quittung); der
# Reconcile-Sweeper alarmiert beim Start über haengende (nicht-terminale) Bestellungen.
ENABLE_ABO=false

# --- Persistenz-Pfade (Default reicht in der Regel) ---
# ORDERS_FILE=./out/orders.jsonl
# SUBS_FILE=./out/subscriptions.jsonl

# --- Concurrency ---
# Max. gleichzeitige Headless-Browser (verhindert OOM). Default 2.
# MAX_CONCURRENT_SCANS=2

# --- Gratis-Teaser: TLS-Toleranz (NUR der kostenlose Scan) ---
# true = der Gratis-Teaser (scanUrl) toleriert TLS-Zertifikatsfehler
# (unvollständige Kette, abgelaufen, self-signed), damit auch SMB-Seiten mit
# schlechter TLS-Konfiguration ein Vorschau-Ergebnis bekommen.
# SICHERHEITS-CAVEAT: Bei aktiviertem Flag ist der Free-Scan anfällig für
# MITM auf die GESCANNTE Seite (kein Zertifikats-Pinning auf dem Hop). Es wird
# nur die TLS-Prüfung gelockert — der SSRF-/IP-Pin + DNS-Rebinding-Schutz bleibt
# in BEIDEN Pfaden aktiv. Der BEZAHLTE Scan (scanSite) bleibt IMMER strikt.
# Default false (strikt). Im Server-.env auf true setzen, wenn Teaser-Reichweite
# über TLS-Strenge gestellt werden soll.
SCAN_TEASER_LENIENT_TLS=false
