# BFSG-Audit — Umgebungsvariablen
# Diese Datei kopieren nach ".env" (oder im Hosting als Variablen eintragen).
# NIEMALS echte Keys in Git committen oder in einen Chat schreiben!

# --- Öffentliche Adresse (für Stripe Erfolg-/Abbruch-Links) ---
PUBLIC_URL=https://bfsg-check.de
PORT=8080

# --- Stripe (du hast es bereits mit deinem Geschäftskonto verbunden) ---
# Findest du im Stripe-Dashboard: Entwickler -> API-Schlüssel
STRIPE_SECRET_KEY=sk_live_oder_test_xxx
# Webhook-Secret: Stripe-Dashboard -> Entwickler -> Webhooks -> Endpoint /webhook anlegen
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- E-Mail-Versand (SMTP eines Anbieters wie Brevo, Postmark, SendGrid) ---
SMTP_HOST=smtp.dein-anbieter.de
SMTP_PORT=587
SMTP_USER=dein-smtp-user
SMTP_PASS=dein-smtp-passwort
FROM_EMAIL=no-reply@bfsg-check.de
FROM_NAME=BFSG-Check

# --- Optional: Betreiber-Alarm bei Erfüllungsfehler ---
ADMIN_EMAIL=admin@bfsg-check.de

# --- Re-Check-Abo (MRR) ---
# Schaltet das monatliche Re-Check-Abo (49 €/Mon) frei. Erst aktivieren,
# wenn der Webhook-Endpoint live und unter Last getestet ist
# (invoice.paid + customer.subscription.deleted müssen ankommen).
ENABLE_ABO=false

# --- Persistenz-Pfade (Default reicht in der Regel) ---
# ORDERS_FILE=./out/orders.jsonl
# SUBS_FILE=./out/subscriptions.jsonl

# --- Concurrency ---
# Max. gleichzeitige Headless-Browser (verhindert OOM). Default 2.
# MAX_CONCURRENT_SCANS=2
