# BFSG-Audit — Umgebungsvariablen
# Diese Datei kopieren nach ".env" (oder im Hosting als Variablen eintragen).
# NIEMALS echte Keys in Git committen oder in einen Chat schreiben!

# --- Öffentliche Adresse (für Stripe Erfolg-/Abbruch-Links) ---
# Marken-Primär ist bfsg-fuchs.de — einzige Wahrheit für alle nutzerseitigen Links.
PUBLIC_URL=https://bfsg-fuchs.de
PORT=8080

# --- Stripe (du hast es bereits mit deinem Geschäftskonto verbunden) ---
# Findest du im Stripe-Dashboard: Entwickler -> API-Schlüssel
STRIPE_SECRET_KEY=sk_live_oder_test_xxx
# Webhook-Secret: Stripe-Dashboard -> Entwickler -> Webhooks -> Endpoint /webhook anlegen
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- E-Mail-Versand (SMTP eines Anbieters wie Brevo, Postmark, SendGrid) ---
SMTP_HOST=smtp.dein-anbieter.de
SMTP_PORT=587
SMTP_USER=dein-smtp-user
SMTP_PASS=dein-smtp-passwort
FROM_EMAIL=no-reply@bfsg-fuchs.de
FROM_NAME=BFSG-Fuchs

# --- Optional: Betreiber-Alarm bei Erfüllungsfehler ---
ADMIN_EMAIL=admin@bfsg-fuchs.de

# --- Re-Check-Abo (MRR) ---
# Schaltet das monatliche Re-Check-Abo frei (Preis = PACKAGES.abo in scanner/app.js).
# Vor dem Scharfschalten (ENABLE_ABO=true) erforderlich:
#   1. Stripe-Webhook abonniert: checkout.session.completed, invoice.paid,
#      invoice.payment_succeeded, customer.subscription.updated,
#      customer.subscription.deleted (Dashboard -> Entwickler -> Webhooks).
#   2. Ein Test-Abo durchspielen (Stripe CLI `stripe trigger invoice.paid` ODER
#      echtes Test-Abo -> sofort kündigen): Re-Scan + Diff + aktualisierte
#      Erklärung + Rechnung + Mail müssen ankommen; Kündigungs-Bestätigung prüfen.
# Idempotenz: In-Memory-Claim gegen Parallel-Duplikate; erfüllte Bestellungen sind
# durabel dedupliziert (recordPaid persistiert die event.id VOR der Quittung); der
# Reconcile-Sweeper alarmiert beim Start über haengende (nicht-terminale) Bestellungen.
ENABLE_ABO=false

# --- Abo-Tier-Modell „Fuchs Re-Check" (ENTWURF, agent-01 23.07.2026) ---
# Schaltet die neuen Paket-IDs (abo-pro/-jahr, abo-business/-jahr, startpaket-*)
# UND das Report-Gate frei. Default AUS: ohne dieses Flag bleibt alles beim
# bisherigen Verhalten ('abo'/'abo-jahr' frei buchbar, neue Pakete existieren
# im Checkout nicht — Merge ist so ohne Stripe-Vorarbeiten harmlos).
# Report-Gate: Re-Check-Abos (alle abo*-Pakete) nur mit bezahltem Erst-Report
# (basis/profi/startpaket) auf derselben E-Mail — sonst HTTP 409 + Hinweis
# aufs Startpaket (Report + 1. Re-Check-Monat inklusive, 30 Tage Trial).
# Vor dem Scharfschalten (ABO_TIERS_ENABLED=true) erforderlich:
#   1. ENABLE_ABO=true muss bereits aktiv sein (Webhook-Events wie oben).
#   2. Landingpage: RECHECK_TIERS_VISIBLE=true + available-Flags der neuen
#      Pakete auf true (Launch-PR, Preis-Sync-CI prüft die Spiegelung).
#   3. Test-Startpaket durchspielen (Stripe-Testmodus): Report-Zeile + Trial-
#      Subscription müssen in Stripe korrekt ankommen (Checkout: Einmalposition
#      + recurring, trial_period_days=30).
#   4. Intervall-/Heartbeat-Umsetzung (agent-01 d10.3/d10.5) muss deployed sein,
#      BEVOR die Tiers Pro/Business als kaufbar beworben werden (2-wöchentlich/
#      wöchentlich sind sonst nicht eingelöst — Claim-Check #12).
ABO_TIERS_ENABLED=false

# Optional: echte Stripe-Preis-IDs für die neuen Pakete (Default: inline
# price_data aus scanner/app.js PACKAGES — keine Dashboard-Vorarbeit nötig).
# Gesetzte IDs ersetzen die inline price_data beim Checkout (Vorbereitung für
# Portal-Tier-Wechsel Starter→Pro→Business). TODO: Owner legt Stripe-Produkte
# an (Tabelle im Tier-PR).
# STRIPE_PRICE_ABO_PRO_MONTH=
# STRIPE_PRICE_ABO_PRO_YEAR=
# STRIPE_PRICE_ABO_BUSINESS_MONTH=
# STRIPE_PRICE_ABO_BUSINESS_YEAR=
# STRIPE_PRICE_STARTPAKET_BASIS=
# STRIPE_PRICE_STARTPAKET_PROFI=

# --- Persistenz-Pfade (Default reicht in der Regel) ---
# ORDERS_FILE=./out/orders.jsonl
# SUBS_FILE=./out/subscriptions.jsonl

# --- Concurrency ---
# Max. gleichzeitige Headless-Browser (verhindert OOM). Default 2.
# MAX_CONCURRENT_SCANS=2

# --- TLS-Toleranz (env-gated, getrennt je Pfad) ---
# true = der Gratis-Teaser (scanUrl) toleriert TLS-Zertifikatsfehler
# (unvollständige Kette, abgelaufen, self-signed), damit auch SMB-Seiten mit
# schlechter TLS-Konfiguration ein Vorschau-Ergebnis bekommen.
# SICHERHEITS-CAVEAT: Bei aktiviertem Flag ist der Scan anfällig für MITM auf die
# GESCANNTE Seite (kein Zertifikats-Pinning auf dem Hop). Es wird NUR die TLS-Prüfung
# gelockert — der SSRF-/IP-Pin + DNS-Rebinding-Schutz bleibt in BEIDEN Pfaden aktiv.
# Default false (strikt).
SCAN_TEASER_LENIENT_TLS=false
# Bezahlter Pfad (scanSite/scanUrl/scanCookie via fulfillOrder): SEPARATES Flag, KEIN
# Fallback auf das Teaser-Flag. Default leer/false = strikt. Nur auf true setzen, wenn
# Lenient-TLS im verkauften Report bewusst gewünscht ist (z. B. um Cert-Mismatch-Seiten
# auszuliefern, die der Gratis-Teaser bereits leniant bestanden hat). SSRF-Schutz unberührt.
SCAN_PAID_LENIENT_TLS=false

# --- Eigene Rechnung (§ 14 UStG) — PFLICHT im Live-Betrieb ---
# Fehlt INVOICE_FROM_ADDRESS im Live-Betrieb, alarmiert app.js beim Start (kein
# Fail-Fast, aber die Rechnung trägt sonst eine leere Anbieter-Anschrift = formfehlerhaft).
INVOICE_FROM_NAME=Max Mustermann
INVOICE_FROM_ADDRESS=Musterstraße 1, 12345 Musterstadt
# Eine von beiden ist seit 01.01.2025 auch für Kleinunternehmer ab 250 € brutto Pflicht
# (§ 33/34a UStDV) — relevant z. B. fürs Profi-Paket (399 €):
INVOICE_TAX_NUMBER=12/345/67890
# INVOICE_USTID=DE123456789
# INVOICE_IBAN=DE00 0000 0000 0000 0000 00   (optional, nur für Rückerstattungen)
# Steuermodus: kleinunternehmer (§ 19 UStG, kein USt-Ausweis) oder regelbesteuerung (19 %).
VAT_MODE=kleinunternehmer

# --- Admin-Endpoints (/admin/*, /api/resend) ---
# Langes Zufallsgeheimnis, z. B. `openssl rand -hex 32`. Ohne Token sind die Admin-Routes gesperrt.
ADMIN_TOKEN=

# --- DOI-Gate für den Gratis-Report (02.07.) ---
# Der Gratis-Report wird erst nach dem Brevo-Double-Opt-in-Klick gesendet. Signaturschlüssel
# für den Confirm-Link (GET /api/lead/confirm). Optional; Fallback: RELEASE_TOKEN_SECRET, dann
# ADMIN_TOKEN. Ohne Secret ist das Gate inaktiv (Lead läuft ungegatet wie zuvor).
LEAD_TOKEN_SECRET=
# Ablageort der durablen Pending-Lead-Queue (Default out/pending-leads.jsonl im Volume).
# PENDING_LEADS_FILE=
