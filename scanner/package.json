{
  "name": "bfsg-audit-scanner",
  "version": "1.1.0",
  "private": true,
  "description": "Automatisierter BFSG-/WCAG-Barrierefreiheits-Scanner mit deutschem Klartext-Report, Stripe-Verkauf und automatischem Report-Versand.",
  "type": "module",
  "bin": {
    "bfsg-audit": "./audit.js"
  },
  "scripts": {
    "start": "node app.js",
    "audit": "node audit.js",
    "test": "node --test \"test/**/*.test.js\"",
    "test:audit": "npm audit --omit=dev",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.0",
    "@axe-core/playwright": "4.10.1",
    "express": "4.22.2",
    "nodemailer": "9.0.3",
    "playwright": "1.55.1",
    "stripe": "17.5.0"
  },
  "devDependencies": {
    "supertest": "7.1.4"
  },
  "overrides": {
    "path-to-regexp": "0.1.13",
    "qs": "6.15.2"
  }
}
