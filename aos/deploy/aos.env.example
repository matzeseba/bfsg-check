# AOS Business-Dashboard — Environment (SSOT: aos/ARCHITECTURE.md §7)
#
# Diese Datei ist die VORLAGE. Auf dem Server erzeugt der Deploy-Workflow
# (.github/workflows/deploy-aos.yml) daraus /opt/aos/aos/deploy/.env und
# fuellt fehlende Werte aus /opt/bfsg-check/deployment/.env auf. Lokal:
# `cp aos.env.example .env` und Werte eintragen. NIE echte Keys committen.

# --- Auth ---
AOS_ADMIN_TOKEN=            # Login-Token (Server: wird beim Erst-Deploy generiert)
AOS_SESSION_SECRET=         # HMAC-Secret fuer Session-Cookies (generiert)

# --- KI-Modelle (Anthropic) ---
ANTHROPIC_API_KEY=          # aus Server-.env vorhanden
AOS_MODEL_JARVIS=claude-sonnet-4-6
AOS_MODEL_AGENTS=claude-sonnet-4-6
PERPLEXITY_API_KEY=         # optional (Research-Agent); leer = Anthropic-only

# --- Datenquellen (read-only Nutzung) ---
STRIPE_SECRET_KEY=          # aus Server-.env (rk_live, read-only Nutzung!)
BREVO_API_KEY=              # aus Server-.env
ADMIN_EMAIL=                # Owner-Mail fuer Lead-/Debrief-Benachrichtigungen
SCANNER_BASE_URL=http://app:8080
SCANNER_ADMIN_TOKEN=        # = ADMIN_TOKEN der Scan-Engine (fuer /admin/*-Daten)
PUBLIC_HEALTH_URL=https://bfsg-fuchs.de/health

# --- Betrieb ---
AOS_DOCKER_SOCK=false       # true nur auf Server (Container-Uebersicht via Proxy)
AOS_DOCKER_PROXY_URL=http://aos-docker-proxy:2375   # read-only docker-socket-proxy
AOS_BASE_URL=https://aos.bfsg-fuchs.de

# --- MCP-Microservices (internes aos_internal-Netz) ---
MCP_RESEARCH_URL=http://aos-mcp-research:8101
MCP_LEADSCORE_URL=http://aos-mcp-leadscore:8102
MCP_COMPETITOR_URL=http://aos-mcp-competitor:8103
MCP_DEBRIEF_URL=http://aos-mcp-debrief:8104

TZ=Europe/Berlin
