# BFSG-OS Cockpit — lokale Konfiguration (kopiere zu .env). NIEMALS committen.
# Alles optional: fehlende Werte → Panel zeigt "nicht konfiguriert", Cockpit läuft trotzdem.

# --- Server ---
COCKPIT_PORT=4317
COCKPIT_HOST=127.0.0.1

# --- Claude Engine (lokal) ---
# Pfad zur claude-CLI (Standard: "claude" aus PATH). Nutzt deine lokale Abo-Auth.
CLAUDE_BIN=claude
# Sicherheits-Cap pro Agenten-Job
CLAUDE_MAX_TURNS=12
# Max. gleichzeitige Agenten-Jobs (lokale CPU/Rate-Limit-Schonung)
JOB_CONCURRENCY=2

# --- Datenquellen (read-only Credentials, liegen lokal auf deinem PC) ---
# Stripe: Restricted Read-Key (rk_live_... mit nur Lese-Rechten) ODER leer lassen
STRIPE_API_KEY=
# Prod-Admin-Endpoint als Daten-Fallback (liest orders über bfsg-fix.de/admin/orders)
PROD_BASE_URL=https://bfsg-fix.de
ADMIN_TOKEN=
# GitHub PAT (nur repo:read / actions:read) für Deploy- & Uptime-Status
GITHUB_TOKEN=
GITHUB_REPO=matzeseba/bfsg-check
# Google Ads (optional; alle 5 nötig für Live-Daten)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# --- Voice ---
STT_URL=http://127.0.0.1:5301
TTS_URL=http://127.0.0.1:5302
VOICE_ENABLED=true

# --- Business-Konstanten ---
CAC_CEILING=177
ADS_BUDGET_MONTH=600
